# Modern CLI tool aliases
alias ls='eza --icons'
alias ll='eza -l --icons'
alias la='eza -la --icons'
alias cat='bat'
alias find='fd'
alias du='dust'
alias df='duf'
alias ps='procs'
# Only alias cd to zoxide if it's been initialized (avoids errors in non-interactive shells)
if (( $+functions[__zoxide_z] )); then
  alias cd='z'
fi
alias cy='claude --dangerously-skip-permissions'
{{- if eq .chezmoi.os "linux" }}
alias grep='rg'
alias top='btm'
{{- end }}

# Git aliases
alias g='git'
alias ga='git add'
alias gc='git commit'
alias gco='git checkout'
alias gp='git push'
alias gl='git pull'
alias gs='git status'
alias gd='git diff'
alias glog='git log --oneline --graph --decorate --all'
alias gb='git branch'
alias gm='git merge'
alias gst='git stash'
alias gsp='git stash pop'

# Development aliases
alias npmg='npm list -g --depth=0'
alias python='python3'
alias serve='python3 -m http.server'
{{- if eq .chezmoi.os "darwin" }}
alias ports='lsof -iTCP -sTCP:LISTEN -n -P'
{{- else }}
alias ports='ss -tulanp'
{{- end }}

# System aliases
alias myip='curl -s https://api.ipify.org'
{{- if eq .chezmoi.os "darwin" }}
alias localip="ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1"
alias cleanup='brew cleanup --prune=all'
{{- else }}
alias localip='ip -4 addr show | grep -oP "(?<=inet\s)\d+(\.\d+){3}" | grep -v 127.0.0.1'
alias cleanup='sudo pacman -Sc --noconfirm && paru -Sc --noconfirm 2>/dev/null || yay -Sc --noconfirm 2>/dev/null || true'
{{- end }}
alias speedtest='curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python3 -'

# Convenience aliases
alias h='history'
alias c='clear'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias path='echo $PATH | tr ":" "\n"'
alias reload='source ~/.zshrc'
alias zshconfig='${EDITOR:-nano} ~/.zshrc'

{{- if eq .chezmoi.os "linux" }}
# SSD Backup monitoring (Linux only)
alias backup-status='systemctl status backup-sync.service'
alias backup-logs='tail -f ~/.local/share/lsyncd/lsyncd.log'
alias backup-check='ls -lth /mnt/backup/arch-backup/dev/ | head -10'
alias backup-size='du -sh /mnt/backup/arch-backup/*'

# Auto-update monitoring
alias update-log='bat /var/log/auto-update.log'
alias update-status='systemctl status auto-update.timer auto-update.service'
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Wake dev PC remotely via Mac Mini WOL relay
alias wake-dev='ssh archie wake-arch'
{{- end }}

# Zellij aliases
alias zj='zellij'
alias za='zellij attach'
alias zan='zellij attach -c'
alias zl='zellij list-sessions'
alias zn='zellij -s'
alias zk='zellij kill-session'
alias zka='zellij kill-all-sessions'
alias zda='zellij delete-all-sessions'
alias zd='zellij action detach'

# Tmux aliases (legacy)
alias t='tmux'
alias ta='tmux attach'
alias tan='tmux a -t'
alias tl='tmux list-sessions'
alias tn='tmux new -s'
alias tk='tmux kill-session -t'
alias tks='tmux kill-server'
alias td='tmux detach'

# Chezmoi dotfiles management
alias cm='chezmoi'
alias cms='chezmoi status'
alias cmd='chezmoi diff'
alias cma='chezmoi apply'
alias cmu='chezmoi update'
alias cme='chezmoi edit'
alias cmcd='chezmoi cd'

# AutoForge (bind to 0.0.0.0 for Tailscale access)
{{- if eq .chezmoi.hostname "archie-goodwynn" }}
alias autoforge="autoforge --host 0.0.0.0"
{{- end }}

# Archie TUI
{{- if eq .chezmoi.hostname "archie-goodwynn" }}
alias archie="openclaw tui --url ws://100.123.23.104:18789"
{{- else }}
alias archie="ssh -t archie 'zsh -ic \"openclaw tui --url ws://100.123.23.104:18789\"'"
{{- end }}

# Yazi
alias ya="yazi"

# Helix
{{ if ne .chezmoi.os "darwin" -}}
alias hx="helix"
{{ end -}}

# Just
alias jg="just -g"

# Quick GitHub repo from current directory
ginit() {
  local name="${1:-$(basename "$PWD")}"
  git init && gh repo create "$name" --private --source=. --remote=origin --push
}

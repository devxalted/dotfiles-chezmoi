local wezterm = require 'wezterm'

local config = wezterm.config_builder()

-- Font
config.font = wezterm.font_with_fallback {
    { family = 'JetBrainsMono Nerd Font', weight = 'Medium' },
    'Symbols Nerd Font Mono',
}
config.font_size = 12.0
config.line_height = 1.2

-- Color scheme: Evergreen
config.colors = {
    foreground = '#909090',
    background = '#000000',
    cursor_bg = '#3D6B44',
    cursor_fg = '#000000',
    cursor_border = '#3D6B44',
    selection_bg = '#2A4A2E',
    selection_fg = '#D0D0D0',
    scrollbar_thumb = '#1a1a1a',
    split = '#014421',

    ansi = {
        '#121212',  -- black
        '#A0522D',  -- red (sienna)
        '#3D6B44',  -- green (forest)
        '#9A7E0A',  -- yellow (muted mustard)
        '#014421',  -- blue (lacoste green)
        '#8B7355',  -- magenta (clay)
        '#4A7C59',  -- cyan (sage)
        '#909090',  -- white
    },
    brights = {
        '#3A3A3A',  -- bright black (gray)
        '#C4724B',  -- bright red (warm sienna)
        '#4A7C59',  -- bright green (sage)
        '#C4A000',  -- bright yellow (mustard)
        '#3D6B44',  -- bright blue (forest)
        '#A89070',  -- bright magenta (light clay)
        '#6B9E78',  -- bright cyan (light sage)
        '#A8A8A8',  -- bright white
    },
}

-- Window appearance
config.window_background_opacity = 0.82
{{- if eq .chezmoi.os "darwin" }}
config.macos_window_background_blur = 10
config.window_decorations = 'RESIZE'
{{- else }}
config.window_decorations = 'NONE'
{{- end }}
config.window_padding = {
    left = 25,
    right = 25,
    top = 20,
    bottom = 20,
}

-- Disable tab bar for clean look
config.enable_tab_bar = false

-- Cursor
config.default_cursor_style = 'BlinkingBar'
config.cursor_blink_rate = 500
config.cursor_blink_ease_in = 'Constant'
config.cursor_blink_ease_out = 'Constant'

-- Scrollbar
config.enable_scroll_bar = false

-- Bell
config.audible_bell = 'Disabled'
config.visual_bell = {
    fade_in_duration_ms = 75,
    fade_out_duration_ms = 75,
    target = 'CursorColor',
}

{{- if eq .chezmoi.os "darwin" }}
-- macOS: OpenGL is more stable/efficient than WebGpu for long sessions
config.front_end = 'OpenGL'
config.max_fps = 120
{{- else }}
-- Linux
config.front_end = 'WebGpu'
config.enable_wayland = true
{{- end }}

-- Keys
config.keys = {
    { key = 'v', mods = 'CTRL', action = wezterm.action.PasteFrom 'Clipboard' },
    { key = 'v', mods = 'CTRL|SHIFT', action = wezterm.action.SendKey { key = 'v', mods = 'CTRL' } },
{{- if eq .chezmoi.os "darwin" }}
    -- macOS: Caps hold sends CTRL, physical Left Ctrl sends CMD
    { key = 't', mods = 'CMD', action = wezterm.action.SpawnTab 'CurrentPaneDomain' },
    { key = 'w', mods = 'CMD', action = wezterm.action.CloseCurrentTab { confirm = true } },
    -- Caps hold + number = tab switching (Caps hold = Ctrl via Karabiner)
    { key = '1', mods = 'CTRL', action = wezterm.action.ActivateTab(0) },
    { key = '2', mods = 'CTRL', action = wezterm.action.ActivateTab(1) },
    { key = '3', mods = 'CTRL', action = wezterm.action.ActivateTab(2) },
    { key = '4', mods = 'CTRL', action = wezterm.action.ActivateTab(3) },
    { key = '5', mods = 'CTRL', action = wezterm.action.ActivateTab(4) },
    { key = '6', mods = 'CTRL', action = wezterm.action.ActivateTab(5) },
    { key = '7', mods = 'CTRL', action = wezterm.action.ActivateTab(6) },
    { key = '8', mods = 'CTRL', action = wezterm.action.ActivateTab(7) },
    { key = '9', mods = 'CTRL', action = wezterm.action.ActivateTab(8) },
    { key = 't', mods = 'CTRL', action = wezterm.action.SpawnTab 'CurrentPaneDomain' },
    { key = 'w', mods = 'CTRL', action = wezterm.action.CloseCurrentTab { confirm = true } },
    -- Splits: physical Left Ctrl + D / Left Ctrl + Shift + D
    { key = 'd', mods = 'CMD', action = wezterm.action.SplitVertical { domain = 'CurrentPaneDomain' } },
    { key = 'd', mods = 'CMD|SHIFT', action = wezterm.action.SplitHorizontal { domain = 'CurrentPaneDomain' } },
    -- Pane navigation: physical Left Ctrl + hjkl (sends CMD)
    { key = 'h', mods = 'CMD', action = wezterm.action.ActivatePaneDirection 'Left' },
    { key = 'j', mods = 'CMD', action = wezterm.action.ActivatePaneDirection 'Down' },
    { key = 'k', mods = 'CMD', action = wezterm.action.ActivatePaneDirection 'Up' },
    { key = 'l', mods = 'CMD', action = wezterm.action.ActivatePaneDirection 'Right' },
{{- end }}
}

-- Misc
config.adjust_window_size_when_changing_font_size = false
config.warn_about_missing_glyphs = false

-- Set TERM for compatibility (wezterm TERM not recognized on remote machines)
config.term = 'xterm-256color'

return config
